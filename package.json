{
  "name": "butmux",
  "version": "0.2.9",
  "description": "butmux - Terminal workspace manager for GitButler, tmux, and Kitty",
  "author": "Kodai Nakamura",
  "type": "module",
  "bin": {
    "butmux": "dist/cli.js"
  },
  "scripts": {
    "dev": "npm run build:cli",
    "build": "tsc --noEmit && npm run build:cli",
    "build:cli": "node scripts/build-cli.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.3",
    "react-devtools-core": "^6.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "main": "dist/cli.js"
}
